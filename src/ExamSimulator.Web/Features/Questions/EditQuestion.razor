@page "/questions/{id:guid}/edit"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore

@inject ExamSimulatorDbContext DbContext
@inject NavigationManager Nav

<PageTitle>Edit Question</PageTitle>

<h1>Edit Question</h1>

@if (_notFound)
{
    <div class="alert alert-warning">Question not found.</div>
    <a href="/questions" class="btn btn-secondary">Back to Questions</a>
}
else if (_model is not null)
{
    <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="EditQuestion">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label">Exam Profile</label>
            <InputSelect class="form-select" @bind-Value="_model.ExamProfileId">
                <option value="">-- select --</option>
                @foreach (var p in _examProfiles)
                {
                    <option value="@p.Id">@p.Name</option>
                }
            </InputSelect>
            <ValidationMessage For="() => _model.ExamProfileId" />
        </div>

        <div class="mb-3">
            <label class="form-label">Question Type</label>
            <div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" id="typeSingle" name="questionType"
                           checked="@(_model.Type == QuestionType.SingleChoice)"
                           @onchange="() => SetType(QuestionType.SingleChoice)" />
                    <label class="form-check-label" for="typeSingle">Single Choice</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" id="typeMultiple" name="questionType"
                           checked="@(_model.Type == QuestionType.MultipleChoice)"
                           @onchange="() => SetType(QuestionType.MultipleChoice)" />
                    <label class="form-check-label" for="typeMultiple">Multiple Choice</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" id="typeOrdering" name="questionType"
                           checked="@(_model.Type == QuestionType.Ordering)"
                           @onchange="() => SetType(QuestionType.Ordering)" />
                    <label class="form-check-label" for="typeOrdering">Ordering</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" id="typeBuildList" name="questionType"
                           checked="@(_model.Type == QuestionType.BuildList)"
                           @onchange="() => SetType(QuestionType.BuildList)" />
                    <label class="form-check-label" for="typeBuildList">Build List</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" id="typeMatching" name="questionType"
                           checked="@(_model.Type == QuestionType.Matching)"
                           @onchange="() => SetType(QuestionType.Matching)" />
                    <label class="form-check-label" for="typeMatching">Matching</label>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Difficulty</label>
            <InputSelect class="form-select" @bind-Value="_model.Difficulty">
                <option value="@Difficulty.Easy">Easy</option>
                <option value="@Difficulty.Medium">Medium</option>
                <option value="@Difficulty.Hard">Hard</option>
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label">Prompt</label>
            <InputTextArea class="form-control" rows="3" @bind-Value="_model.Prompt" />
            <ValidationMessage For="() => _model.Prompt" />
        </div>

        <div class="mb-3">
            <label class="form-label">Topic Tag</label>
            <InputText class="form-control" @bind-Value="_model.TopicTag" />
            <ValidationMessage For="() => _model.TopicTag" />
        </div>

        <div class="mb-3">
            <label class="form-label">
                Options
                @if (_model.Type == QuestionType.SingleChoice)
                {
                    <small class="text-muted ms-1">(select the correct answer)</small>
                }
                else if (_model.Type == QuestionType.MultipleChoice)
                {
                    <small class="text-muted ms-1">(select all correct answers)</small>
                }
                else if (_model.Type == QuestionType.BuildList)
                {
                    <small class="text-muted ms-1">(define the pool of items — use "Add →" to build the answer)</small>
                }
                else if (_model.Type == QuestionType.Matching)
                {
                    <small class="text-muted ms-1">(one premise per row — these are the left-hand column)</small>
                }
                else
                {
                    <small class="text-muted ms-1">(arrange options in the correct order)</small>
                }
            </label>
            @for (int i = 0; i < _model.Options.Count; i++)
            {
                var index = i;
                <div class="input-group mb-2">
                    @if (_model.Type == QuestionType.Ordering)
                    {
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => MoveOptionUp(index)" disabled="@(index == 0)" title="Move up">↑</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => MoveOptionDown(index)" disabled="@(index == _model.Options.Count - 1)" title="Move down">↓</button>
                    }
                    else if (_model.Type == QuestionType.Matching)
                    {
                        @* no prefix button for Matching premises — pairings handled below *@
                    }
                    else if (_model.Type == QuestionType.BuildList)
                    {
                        <button type="button" class="btn btn-outline-primary btn-sm"
                                @onclick="() => AddToAnswer(index)"
                                disabled="@(_model.BuildListAnswer.Contains(index))"
                                title="Add to answer">Add →</button>
                    }
                    else
                    {
                        <div class="input-group-text">
                            @if (_model.Type == QuestionType.SingleChoice)
                            {
                                <input type="radio" name="correctOption"
                                       checked="@(_model.CorrectOptionIndex == index)"
                                       @onchange="() => _model.CorrectOptionIndex = index"
                                       title="Mark as correct" />
                            }
                            else
                            {
                                <input type="checkbox"
                                       checked="@_model.SelectedIndices.Contains(index)"
                                       @onchange="e => ToggleIndex(index, (bool)e.Value!)"
                                       title="Mark as correct" />
                            }
                        </div>
                    }
                    <input type="text" class="form-control" value="@_model.Options[index]"
                           @oninput="e => _model.Options[index] = e.Value?.ToString() ?? string.Empty"
                           placeholder="Option @(index + 1)" />
                    @if (_model.Options.Count > 2)
                    {
                        <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveOption(index)">✕</button>
                    }
                </div>
            }
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AddOption">+ Add Option</button>
        </div>

        @if (_model.Type == QuestionType.Matching)
        {
            <div class="mb-3">
                <label class="form-label fw-semibold">Responses <small class="text-muted fw-normal">(right-hand column — may include distractors)</small></label>
                @for (int i = 0; i < _model.MatchingTargets.Count; i++)
                {
                    var tIdx = i;
                    <div class="input-group mb-2">
                        <input type="text" class="form-control" value="@_model.MatchingTargets[tIdx]"
                               @oninput="e => _model.MatchingTargets[tIdx] = e.Value?.ToString() ?? string.Empty"
                               placeholder="Response @(tIdx + 1)" />
                        @if (_model.MatchingTargets.Count > _model.Options.Count)
                        {
                            <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveTarget(tIdx)">✕</button>
                        }
                    </div>
                }
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AddTarget">+ Add Response</button>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Pairs <small class="text-muted fw-normal">(for each premise, select its correct response)</small></label>
                @for (int i = 0; i < _model.Options.Count; i++)
                {
                    var pIdx = i;
                    <div class="row align-items-center mb-2">
                        <div class="col-md-5">
                            <span class="form-control-plaintext">@(string.IsNullOrWhiteSpace(_model.Options[pIdx]) ? $"(Premise {pIdx + 1})" : _model.Options[pIdx])</span>
                        </div>
                        <div class="col-auto text-muted">→</div>
                        <div class="col-md-5">
                            <select class="form-select" value="@_model.MatchingPairs[pIdx]"
                                    @onchange="e => _model.MatchingPairs[pIdx] = int.TryParse(e.Value?.ToString(), out var v) ? v : -1">
                                <option value="-1">— select —</option>
                                @for (int t = 0; t < _model.MatchingTargets.Count; t++)
                                {
                                    var tIdx = t;
                                    <option value="@tIdx">@(string.IsNullOrWhiteSpace(_model.MatchingTargets[tIdx]) ? $"(Response {tIdx + 1})" : _model.MatchingTargets[tIdx])</option>
                                }
                            </select>
                        </div>
                    </div>
                }
            </div>
        }

        @if (_model.Type == QuestionType.BuildList)
        {
            <div class="mb-3">
                <label class="form-label fw-semibold">Answer <small class="text-muted fw-normal">(ordered — must be a proper subset of the pool)</small></label>
                @if (_model.BuildListAnswer.Count == 0)
                {
                    <p class="text-muted">No items added yet. Use "Add →" above.</p>
                }
                @for (int i = 0; i < _model.BuildListAnswer.Count; i++)
                {
                    var ansIdx = i;
                    var optIdx = _model.BuildListAnswer[ansIdx];
                    <div class="input-group mb-2">
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => MoveAnswerUp(ansIdx)" disabled="@(ansIdx == 0)" title="Move up">↑</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => MoveAnswerDown(ansIdx)" disabled="@(ansIdx == _model.BuildListAnswer.Count - 1)" title="Move down">↓</button>
                        <span class="form-control">@_model.Options[optIdx]</span>
                        <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveFromAnswer(ansIdx)" title="Remove from answer">✕</button>
                    </div>
                }
            </div>
        }

        <div class="mb-3">
            <label class="form-label">Explanation <span class="text-muted">(optional)</span></label>
            <InputTextArea class="form-control" rows="2" @bind-Value="_model.Explanation" />
        </div>

        @if (_errorMessage is not null)
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/questions" class="btn btn-secondary ms-2">Cancel</a>
    </EditForm>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private EditQuestionModel? _model;
    private List<ExamProfile> _examProfiles = [];
    private bool _notFound;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        _examProfiles = await DbContext.ExamProfiles.AsNoTracking().OrderBy(p => p.Name).ToListAsync();

        var question = await DbContext.Questions.AsNoTracking().FirstOrDefaultAsync(q => q.Id == Id);
        if (question is null)
        {
            _notFound = true;
            return;
        }

        _model = new EditQuestionModel
        {
            ExamProfileId = question.ExamProfileId,
            Type = question.Type,
            Difficulty = question.Difficulty,
            Prompt = question.Prompt,
            TopicTag = question.TopicTag,
            Explanation = question.Explanation ?? string.Empty,
            Options = question.Options.ToList(),
        };

        if (question.Type == QuestionType.SingleChoice)
        {
            _model.CorrectOptionIndex = question.CorrectOptionIndices[0];
        }
        else if (question.Type == QuestionType.MultipleChoice)
        {
            _model.SelectedIndices = [.. question.CorrectOptionIndices];
        }
        else if (question.Type == QuestionType.BuildList)
        {
            _model.BuildListAnswer = question.CorrectOptionIndices.ToList();
        }
        else if (question.Type == QuestionType.Matching)
        {
            _model.MatchingTargets = question.MatchingTargets?.ToList() ?? [];
            _model.MatchingPairs = question.CorrectOptionIndices.ToList();
        }
        // Ordering: correct order is implied by options list order; no extra init needed
    }

    private void AddOption()
    {
        _model!.Options.Add(string.Empty);
        if (_model.Type == QuestionType.Matching)
        {
            _model.MatchingPairs.Add(-1);
            if (_model.MatchingTargets.Count < _model.Options.Count)
                _model.MatchingTargets.Add(string.Empty);
        }
    }

    private void RemoveOption(int index)
    {
        _model!.Options.RemoveAt(index);
        if (_model.CorrectOptionIndex >= _model.Options.Count)
            _model.CorrectOptionIndex = _model.Options.Count - 1;
        _model.SelectedIndices.RemoveWhere(i => i == index);
        var shifted = _model.SelectedIndices.Where(i => i > index).ToList();
        foreach (var i in shifted)
        {
            _model.SelectedIndices.Remove(i);
            _model.SelectedIndices.Add(i - 1);
        }        _model.BuildListAnswer.RemoveAll(i => i == index);
        for (int i = 0; i < _model.BuildListAnswer.Count; i++)
            if (_model.BuildListAnswer[i] > index) _model.BuildListAnswer[i]--;
        if (_model.Type == QuestionType.Matching && index < _model.MatchingPairs.Count)
            _model.MatchingPairs.RemoveAt(index);
    }

    private void SetType(QuestionType type)
    {
        _model!.Type = type;
        _model.SelectedIndices.Clear();
        _model.BuildListAnswer.Clear();
        _model.MatchingPairs.Clear();
        if (type == QuestionType.Matching)
        {
            SyncMatchingPairs();
            if (_model.MatchingTargets.Count < _model.Options.Count)
                while (_model.MatchingTargets.Count < _model.Options.Count)
                    _model.MatchingTargets.Add(string.Empty);
        }
    }

    private void SyncMatchingPairs()
    {
        while (_model!.MatchingPairs.Count < _model.Options.Count)
            _model.MatchingPairs.Add(-1);
        while (_model.MatchingPairs.Count > _model.Options.Count)
            _model.MatchingPairs.RemoveAt(_model.MatchingPairs.Count - 1);
    }

    private void AddTarget() => _model!.MatchingTargets.Add(string.Empty);

    private void RemoveTarget(int index)
    {
        _model!.MatchingTargets.RemoveAt(index);
        for (int i = 0; i < _model.MatchingPairs.Count; i++)
        {
            if (_model.MatchingPairs[i] == index) _model.MatchingPairs[i] = -1;
            else if (_model.MatchingPairs[i] > index) _model.MatchingPairs[i]--;
        }
    }

    private void ToggleIndex(int index, bool isChecked)
    {
        if (isChecked)
            _model!.SelectedIndices.Add(index);
        else
            _model!.SelectedIndices.Remove(index);
    }

    private void MoveOptionUp(int index)
    {
        if (index <= 0) return;
        (_model!.Options[index - 1], _model.Options[index]) = (_model.Options[index], _model.Options[index - 1]);
    }

    private void MoveOptionDown(int index)
    {
        if (index >= _model!.Options.Count - 1) return;
        (_model.Options[index], _model.Options[index + 1]) = (_model.Options[index + 1], _model.Options[index]);
    }

    private void AddToAnswer(int optionIndex)
    {
        if (!_model!.BuildListAnswer.Contains(optionIndex))
            _model.BuildListAnswer.Add(optionIndex);
    }

    private void MoveAnswerUp(int ansIdx)
    {
        if (ansIdx <= 0) return;
        (_model!.BuildListAnswer[ansIdx - 1], _model.BuildListAnswer[ansIdx]) = (_model.BuildListAnswer[ansIdx], _model.BuildListAnswer[ansIdx - 1]);
    }

    private void MoveAnswerDown(int ansIdx)
    {
        if (ansIdx >= _model!.BuildListAnswer.Count - 1) return;
        (_model.BuildListAnswer[ansIdx], _model.BuildListAnswer[ansIdx + 1]) = (_model.BuildListAnswer[ansIdx + 1], _model.BuildListAnswer[ansIdx]);
    }

    private void RemoveFromAnswer(int ansIdx) => _model!.BuildListAnswer.RemoveAt(ansIdx);

    private async Task HandleSubmit()
    {
        _errorMessage = null;
        try
        {
            IEnumerable<int> correctIndices;
            IEnumerable<string>? matchingTargets = null;

            if (_model!.Type == QuestionType.SingleChoice)
                correctIndices = [_model.CorrectOptionIndex];
            else if (_model.Type == QuestionType.Ordering)
                correctIndices = Enumerable.Range(0, _model.Options.Count);
            else if (_model.Type == QuestionType.BuildList)
                correctIndices = _model.BuildListAnswer;
            else if (_model.Type == QuestionType.Matching)
            {
                SyncMatchingPairs();
                correctIndices = _model.MatchingPairs;
                matchingTargets = _model.MatchingTargets;
            }
            else
                correctIndices = _model.SelectedIndices.Order();

            var updated = new Question(
                Id,
                _model.ExamProfileId,
                _model.Type,
                _model.Difficulty,
                _model.Prompt,
                _model.Options,
                correctIndices,
                _model.TopicTag,
                _model.Explanation,
                matchingTargets);

            DbContext.Questions.Update(updated);
            await DbContext.SaveChangesAsync();
            DbContext.ChangeTracker.Clear();
            Nav.NavigateTo("/questions");
        }
        catch (ArgumentException ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private sealed class EditQuestionModel
    {
        public string ExamProfileId { get; set; } = string.Empty;
        public string Prompt { get; set; } = string.Empty;
        public string TopicTag { get; set; } = string.Empty;
        public List<string> Options { get; set; } = [];
        public QuestionType Type { get; set; }
        public Difficulty Difficulty { get; set; }
        public string Explanation { get; set; } = string.Empty;
        public int CorrectOptionIndex { get; set; }
        public HashSet<int> SelectedIndices { get; set; } = [];
        public List<int> BuildListAnswer { get; set; } = [];
        public List<string> MatchingTargets { get; set; } = [];
        public List<int> MatchingPairs { get; set; } = [];
    }
}
