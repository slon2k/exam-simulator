@page "/questions"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore

@inject ExamSimulatorDbContext DbContext
@inject IJSRuntime JS

<PageTitle>Questions</PageTitle>

<h1>Questions</h1>

<p><a href="/questions/create" class="btn btn-primary">Create Question</a></p>

@if (_questions is null)
{
    <p>Loading...</p>
}
else if (_questions.Count == 0)
{
    <p>No questions yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Exam Profile</th>
                <th>Prompt</th>
                <th>Topic</th>
                <th>Type</th>
                <th>Difficulty</th>
                <th>Options</th>
                <th>Correct</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var q in _questions)
            {
                <tr>
                    <td>@q.ExamProfileId</td>
                    <td>@q.Prompt</td>
                    <td>@q.TopicTag</td>
                    <td>@q.Type</td>
                    <td>@q.Difficulty</td>
                    <td>@q.Options.Count</td>
                    <td>@string.Join(", ", q.CorrectOptionIndices.Select(i => q.Options[i]))</td>
                    <td>
                        <a href="/questions/@q.Id/edit" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                        <button type="button" class="btn btn-sm btn-outline-danger"
                                @onclick="() => DeleteQuestion(q)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Question>? _questions;

    protected override async Task OnInitializedAsync()
    {
        _questions = await DbContext.Questions.AsNoTracking().ToListAsync();
    }

    private async Task DeleteQuestion(Question question)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete question: \"{question.Prompt}\"?");
        if (!confirmed) return;

        var entity = await DbContext.Questions.FindAsync(question.Id);
        if (entity is null) return;

        DbContext.Questions.Remove(entity);
        await DbContext.SaveChangesAsync();
        _questions!.Remove(question);
    }
}
