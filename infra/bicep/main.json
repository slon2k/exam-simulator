                "description": "Name of the Azure SQL logical server."
              }
            },
            "databaseName": {
              "type": "string",
              "metadata": {
                "description": "Name of the database."
              }
            },
            "location": {
              "type": "string"
            },
            "adminLogin": {
              "type": "string",
              "metadata": {
                "description": "SQL Server administrator login name."
              }
            },
            "adminPassword": {
              "type": "securestring",
