            }
          },
          "parameters": {
            "name": {
              "type": "string",
              "metadata": {
                "description": "Name of the Key Vault. Must be 3–24 alphanumeric characters or hyphens."
              }
            },
            "location": {
              "type": "string"
            },
            "appServicePrincipalId": {
              "type": "string",
              "metadata": {
                "description": "Principal ID of the App Service system-assigned managed identity."
              }
